---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'LDH - Rowery';
const description = 'Serwis i sprzedaż rowerów elektrycznych';
const permalink = Astro.site.href;
---

<BaseLayout title={title} description={description} permalink={permalink}>
  <div class="home-container">
    <div class="home-copy">
      <h1>LDH - Rowery</h1>
      <p>Serwis i sprzedaż rowerów elektrycznych.</p>
      <p>42-700 Lisowice, ul. Lubliniecka 10B</p>
      <p>tel. 781 344 144</p>
    </div>

    <div class="hero-image-container">
      <div class="hero-image-themed"></div>
    </div>
  </div>
</BaseLayout>

<style>
  .home-container {
    align-items: center;
    display: flex;
    flex: 1;
    justify-content: space-between;
    margin: 2em auto;
    min-height: 400px;
    width: 100%;
    max-width: 1200px;
  }

  .home-copy {
    /* To pozwoli tekstowi zająć dostępną przestrzeń po lewej */
    flex: 1;
    padding: 0 2em 0 0;
    text-align: left;
  }

  .home-copy h1 {
    font-size: 3.5rem;
    font-weight: 700;
    margin-bottom: 0.5em;
    line-height: 1.2;
  }

  .home-copy p {
    font-size: 1.4em;
    margin: 0.4em 0;
  }

  .hero-image-container {
    flex: 1;
    display: flex;
    justify-content: flex-end;
  }

  .hero-image-themed {
    width: 550px;
    height: 466px;
    background-image: url('/assets/logo.webp');
    background-size: contain;
    background-repeat: no-repeat;
    background-position: center right;
    display: block;
  }

  :global(.theme-dark) .hero-image-themed {
    background-image: url('/assets/logo-dark.webp');
  }

  /* Responsywność dla laptopów/tabletów */
  @media (max-width: 1200px) {
    .home-copy h1 {
      font-size: 2.8rem;
    }
    .hero-image-themed {
      width: 450px;
      height: 380px;
    }
  }

  /* Responsywność dla telefonów */
  @media (max-width: 900px) {
    .home-container {
      flex-direction: column-reverse;
      text-align: center;
      margin-top: 1em;
    }

    .home-copy {
      flex: 0; /* Tutaj flex: 0 jest OK, bo na mobile chcemy dopasowanie do treści */
      padding: 2em 0;
      text-align: center;
    }

    .home-copy h1 {
      font-size: 2.2rem;
    }

    .hero-image-container {
      justify-content: center;
    }

    .hero-image-themed {
      width: 300px;
      height: 250px;
      background-position: center;
    }
  }
</style>
