---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'LDH - Rowery';
const description = 'Serwis i sprzedaż rowerów elektrycznych';
const permalink = Astro.site.href;
---

<BaseLayout title={title} description={description} permalink={permalink}>
  <div class="home-container">
    <div class="home-copy">
      <h1>LDH - Rowery</h1>
      <p>Serwis i sprzedaż rowerów elektrycznych.</p>
      <p>42-700 Lisowice, ul. Lubliniecka 10B</p>
      <p>tel. 781 344 144</p>
    </div>

    <div class="hero-image-container">
      <div class="hero-image-themed"></div>
    </div>
  </div>
</BaseLayout>

<style>
  .home-container {
    .home-container {
    align-items: center;
    display: flex;
    flex: 1;
    justify-content: space-between; /* Zmieniono z center na space-between */
    margin: 2em auto;              /* Dodano auto dla centrowania kontenera */
    min-height: 400px;
    width: 100%;                   /* Wymuszenie pełnej szerokości */
    max-width: 1200px;             /* Maksymalna szerokość treści */
  }
  }

  .home-copy {
    flex: 1;
    padding-right: 2em;
    padding: 0 1em;
  }

  .home-copy h1 {
    font-weight: 700;
    margin-bottom: 0.5em;
    line-height: 1.3;
  }

  .home-copy p {
    font-size: 1.4em;
  }

 .hero-image-container {
    flex: 1;                       /* Obrazek zajmuje połowę dostępnego miejsca */
    display: flex;
    justify-content: flex-end;     /* Dosunięcie obrazka do prawej krawędzi */
  }

  .hero-image-themed {
    width: 100%;                   /* Teraz obrazek będzie elastyczny */
    width: 550px;
    height: 466px;
    background-image: url('/assets/logo.webp');
    background-size: contain;
    background-repeat: no-repeat;
    background-position: center; /* Dodane dla lepszego centrowania */
    display: block;
  }

  :global(.theme-dark) .hero-image-themed {
    background-image: url('/assets/logo-dark.webp');
  }

  .hero-image-container picture {
    display: block;
    min-height: 250px;
  }

  .caption {
    font-size: .8em;
    font-style: italic;
    text-align: left;
  }

  .hero-image {
    width: 100%;
    max-width: 550px;
    margin-bottom: 1em;
  }

@media (max-width: 1200px) {
    .hero-image-themed {
      width: 400px;
      height: 340px; /* Proporcjonalnie mniej */
    }
  }

  @media (max-width: 800px) {
    .home-container {
      flex-direction: column-reverse; /* Obrazek nad tekstem na mobile */
      text-align: center;
      margin-top: 1em;
    }
  }

 .home-copy {
      flex: 0;
      padding-bottom: 2em;
      text-align: center;
  }
  .home-copy h1 {
      font-size: 2.5rem;
    }

    .hero-image-themed {
      height: 300px;               /* Mniejszy obrazek na telefonach */
      background-position: center;
    }
  
</style>
