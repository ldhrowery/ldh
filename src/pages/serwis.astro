---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'O firmie';
const description = 'O nas.';
const permalink = `${Astro.site.href}serwis`;
---

<BaseLayout title={title} description={description} permalink={permalink} current="serwis">
  <div class="container">
    <h1>Serwis</h1>
    <figure class="about-image">
      
    </figure>
  </div>
  <div class="tables-wrapper">
    <div class="table-container">
      <table>
    <thead>
      <tr>
        <th>Usługi - rower elektryczny</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td>Diagnostyka</td>
      </tr>
      <tr>
        <td>Aktualizacje</td>
      </tr>
      <tr>
        <td>Parowanie podzespołów</td>
      </tr>
      <tr>
        <td>Regeneracja baterii</td>
      </tr>
      <tr>
        <td>Test pojemności baterii</td>
      </tr>
      <tr>
        <td>Wymiana/naprawa podzespołów</td>
      </tr>
   </tbody>
  </table>
    </div>

    <div class="table-container">
      <table>
    <thead>
      <tr>
        <th>Usługi - serwis mechaniczny</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td>Budowa/naprawa kół</td>
      </tr>
