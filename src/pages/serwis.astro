      </tr>
      <tr>
        <td>Serwis zawieszenia</td>
      </tr>
      <tr>
        <td>Przeglądy serwisowe i gwarancyjne</td>
      </tr>
      <tr>
        <td>Obsługa hydrauliki hamulcowej</td>
      </tr>
      <tr>
        <td>Montaż akcesoriów</td>
      </tr>
   </tbody>
  </table>
    </div>
  </div>
  <div class="tables-wrapper">
    <div class="table-container">
      <table>
    <thead>
      <tr>
        <th>Obsługiwane systemy</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td>Bosch</td>
      </tr>
      <tr>
        <td>Shimano Steps</td>
      </tr>
      <tr>
        <td>ION</td>
      </tr>
      <tr>
        <td>Fit 1.0 oraz 2.0</td>
      </tr>
      <tr>
        <td>Panasonic</td>
      </tr>
      <tr>
        <td>Innergy</td>
      </tr>
      <tr>
        <td>Impulse</td>
      </tr>
      <tr>
        <td>BMZ</td>
      </tr>
      <tr>
        <td>Bafang</td>
      </tr>
      <tr>
        <td>BMZ</td>
      </tr>
      <tr>
        <td>BROSE</td>
      </tr>
   </tbody>
  </table>
    </div>

    <div class="table-container">
      <table>
    <thead>
      <tr>
        <th>Obsługiwane Marki rowerowe</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td>Gazelle</td>
      </tr>
      <tr>
        <td>Sparta</td>
      </tr>
      <tr>
        <td>Koga</td>
      </tr>
      <tr>
