      </tr>
      <tr>
        <td>Flyer</td>
      </tr>
      <tr>
        <td>Prophete</td>
      </tr>
      <tr>
        <td>Kalkhoff</td>
      </tr>
      <tr>
        <td>Victoria</td>
      </tr>
      <tr>
        <td>Diamant</td>
      </tr>
      <tr>
        <td>KTM</td>
      </tr>
      <tr>
        <td>CUBE</td>
      </tr>
   </tbody>
  </table>
    </div>
  </div>
</BaseLayout>

<style>
  .about-image {
    float: right;
    margin: -3em -7em 2em 2em;
    max-width: 300px;
  }

  .about-image img {
    border-radius: 8px;
    margin-bottom: 1.5em;
  }

  @media (max-width: 1020px) {
    .about-image {
      float: none;
      margin: 0 auto 2em;
    }
  }

  table {
    width: 100%;
    border-collapse: collapse;
    font-family: var(--font-heading);
    /* Używamy półprzezroczystego tła lub zmiennej, jeśli ją masz */
    background: var(--background-color, #fff); 
    border: 1px solid var(--border-color, #ddd);
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    color: var(--text-color, #222); /* Zapewnia, że tekst reaguje na motyw */
  }

  td {
    padding: 1rem;
    text-align: left;
    border-bottom: 1px solid var(--border-color, #eee);
    /* To wymusi kolor tekstu zgodny z motywem strony */
    color: inherit; 
  }

  th {
    background-color: #222; /* Nagłówek zostaje ciemny */
    color: #fff;            /* Tekst w nagłówku zawsze biały */
    text-transform: uppercase;
    font-size: 0.85rem;
    letter-spacing: 1px;
  }

 tr:hover {
    background-color: rgba(128, 128, 128, 0.1);
  }

  /* Responsywność */
  @media (max-width: 600px) {
    th, td {
      padding: 0.5rem;
      font-size: 0.9rem;
    }
  }
  .tables-wrapper {
    display: flex;       /* Ustawia elementy obok siebie */
    gap: 20px;          /* Odstęp między tabelami */
    width: 100%;
    flex-wrap: wrap;    /* Ważne: na telefonach tabele wskoczą jedna pod drugą */
  }

  .table-container {
    flex: 1;            /* Każda tabela zajmie tyle samo miejsca (ok. 50%) */
    min-width: 300px;   /* Jeśli ekran będzie węższy niż 600px, tabele się rozdzielą */
  }
</style>
